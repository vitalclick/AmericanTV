# Copy to `.env` and edit. Loaded by flutter_dotenv at app startup.

# Laravel API base URL. Phase 0/1 talks to /api/v1.
API_BASE_URL=http://localhost:8000/api/v1

# RevenueCat public SDK keys (per-platform). Find these in the RevenueCat
# dashboard once you've registered the iOS + Android apps.
REVENUECAT_IOS_KEY=
REVENUECAT_ANDROID_KEY=

# Google OAuth — only needed on Android (iOS uses the URL scheme in Info.plist).
GOOGLE_OAUTH_CLIENT_ID_ANDROID=

# Sentry/crash reporting toggle for dev builds.
ENABLE_CRASHLYTICS=false
