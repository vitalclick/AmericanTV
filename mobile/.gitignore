# Platform projects are now CHECKED IN (3.0.0+14 onward).
# Rationale: lets us land per-project customizations (Info.plist,
# entitlements, gradle signing) on the same branch as the Dart change
# that needs them. Codemagic's `flutter create . --no-overwrite` step
# is a no-op when these exist; it still runs as a safety net for
# fresh clones or platform additions.
#
# Web / desktop platforms are not supported.
/web/
/macos/
/linux/
/windows/

# Build outputs from the platform projects themselves.
android/.gradle/
android/build/
android/app/build/
android/captures/
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Generated.xcconfig
ios/Runner/GeneratedPluginRegistrant.h
ios/Runner/GeneratedPluginRegistrant.m
ios/build/

# Backup files left by sed on the platform-identifier rewrites.
*.bak
*.bak2
*.bak3

# Env + secrets
.env

# Firebase config files are committed (private repo) to keep Codemagic
# env-group footprint small. The Google-recommended .gitignore lists
# them, but for a single-environment app in a private repo, the
# convenience of "drop the file in once and never touch it again"
# outweighs the rotation flexibility env-vars give. If you ever
# flip this repo public, restore the entries and move both files
# back to Codemagic env vars (base64-encoded) instead.

# Android signing materials. NEVER commit these — they get uploaded to
# Codemagic's encrypted code-signing storage. Losing them means the
# next AAB Play Store sees won't validate.
*.jks
*.keystore
key.properties
android/key.properties
android/app/upload-keystore.jks
android/app/key.properties

# OS
.DS_Store
Thumbs.db
